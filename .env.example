# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Standalone оператор (один оператор, N магазинов Avito) ──
# Логин/пароль для входа в инструмент. ОБЯЗАТЕЛЬНО сменить в проде.
OPERATOR_LOGIN=operator
OPERATOR_PASSWORD=change-me
# Фиксированный UUID строки оператора в users (под ним живут все Avito-сессии)
OPERATOR_USER_ID=00000000-0000-4000-8000-000000000001
# Сколько магазинов (account_index) разрешено подключить
OPERATOR_AVITO_ACCOUNT_LIMIT=20
# Куда воркер кладёт скрин+HTML при сбое постинга/действий (выверка селекторов).
# По умолчанию <tmp>/avito-debug
AVITO_DEBUG_DIR=

# Telegram Bots
TELEGRAM_CLIENT_BOT_TOKEN=your-client-bot-token
TELEGRAM_SHIPPER_BOT_TOKEN=your-shipper-bot-token
TELEGRAM_OWNER_BOT_TOKEN=your-owner-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_ORDERS_GROUP_ID=your-orders-group-id
OWNER_TELEGRAM_ID=your-owner-telegram-id

# Redis (BullMQ Jobs)
# Local: redis://localhost:6379
# Upstash: rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# Jobs API Security (для production)
# Сгенерировать: openssl rand -hex 32
JOBS_API_SECRET=your-secret-key-for-jobs-api

# AI (OpenAI) — описания/названия/чат-агент, Whisper (голос), TTS
OPENAI_API_KEY=your-openai-api-key

# AI (Google Gemini «Nano Banana») — генератор обложек объявлений
# gemini-2.5-flash-image. Без ключа генератор обложек = pass-through (заглушка).
GEMINI_API_KEY=your-gemini-api-key

# Delivery Tracking (Track.global API через RapidAPI)
# Подписка: https://rapidapi.com → Track.global
# Два ключа: RapidAPI key + Bearer token от Track.global
TRACK_GLOBAL_RAPIDAPI_KEY=your-rapidapi-key
TRACK_GLOBAL_BEARER_TOKEN=your-track-global-bearer-token
